{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axum Vue Admin",
  "version": "0.1.0",
  "identifier": "com.axumvueadmin.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Axum Vue Admin",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
