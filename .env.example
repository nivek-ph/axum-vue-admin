# -----------------------------------------------------------------------------
# Logging (crate: tracing-subscriber; read by Rust at runtime)
# -----------------------------------------------------------------------------
RUST_LOG="info"
LOG_LEVEL="info"
LOG_FORMAT=compact
LOG_SPAN_EVENTS=FMT::NEW|FMT::EXIT
LOG_CONSOLE_ENABLED=true
LOG_OTEL_LOGS_ENABLED=true
LOG_SERVICE_NAME="ava"

# -----------------------------------------------------------------------------
# OpenTelemetry — see https://github.com/nivek-ph/tracing-otel-extra/blob/main/.env.example
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# -----------------------------------------------------------------------------
# Http server
# -----------------------------------------------------------------------------
HTTP_PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgres://postgres:postgres@localhost/axum_vue_admin"

# -----------------------------------------------------------------------------
# Redis 8 or newer
# -----------------------------------------------------------------------------
REDIS_URL="redis://127.0.0.1:6379/"

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET="change-me"

# -----------------------------------------------------------------------------
# Bootstrap admin
# -----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="123456"
ADMIN_NICKNAME="Administrator"

# -----------------------------------------------------------------------------
# Frontend (optional; copy into apps/desktop `.env`, `.env.local`, etc.)
# -----------------------------------------------------------------------------
# Overrides Axios base URL. Default when unset is http://127.0.0.1:3000/api
# VITE_API_BASE_URL="http://127.0.0.1:3000/api"
